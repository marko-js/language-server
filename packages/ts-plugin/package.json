    "!**/__tests__",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsx build.mts"
  },
  "devDependencies": {
    "@marko/language-server": "^3.0.1",
    "@marko/language-tools": "^2.5.59",
