{
  "name": "@marko/language-server",
  "version": "3.3.3",
  "description": "Marko Language Server",
  "keywords": [
    "autocomplete",
    "intellisense",
    "language",
    "marko",
    "server"
  ],
  "homepage": "https://github.com/marko-js/language-server/tree/main/packages/language-server/README.md",
  "bugs": "https://github.com/marko-js/language-server/issues/new?template=bug-report.yml",
  "repository": {
    "type": "git",
    "url": "https://github.com/marko-js/language-server/tree/main/packages/language-server"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "default": "./dist/browser.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "bin": {
    "marko-language-server": "./bin.js"
  },
  "files": [
    "dist",
    "!**/__tests__",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsx build.mts",
    "test": "mocha './src/**/__tests__/*.test.ts'",
    "test:update": "mocha './src/**/__tests__/*.test.ts' --update"
  },
  "dependencies": {
    "@luxass/strip-json-comments": "^1.4.0",
    "@marko/compiler": "^5.41.3",
    "@marko/language-tools": "^2.6.5",
    "axe-core": "^4.12.1",
    "htmljs-parser": "^5.12.1",
    "jsdom": "^29.1.1",
    "marko": "^5.39.25",
    "prettier": "^3.8.4",
    "prettier-plugin-marko": "^4.0.10",
    "relative-import-path": "^1.0.1",
    "typescript": "^6.0.3",
    "vscode-css-languageservice": "^6.3.10",
    "vscode-languageserver": "^10.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "tsx": "^4.22.4"
  }
}
