{
  "name": "marko-language-server-repo",
  "private": true,
  "scripts": {
    "@ci:build": "pnpm run build",
    "@ci:lint": "pnpm run lint",
    "@ci:release": "pnpm run build && changeset publish && pnpm -r --if-present run release && pnpm install --frozen-lockfile",
    "@ci:test": "pnpm test",
    "@ci:version": "pnpm run build && pnpm run format && changeset version && pnpm install --lockfile-only",
    "build": "tsc -b && NODE_ENV=production pnpm -r run build",
    "build:dev": "tsx ./packages/vscode/build.mts",
    "change": "changeset add",
    "format": "eslint --fix .; prettier . --write --log-level=warn",
    "lint": "eslint . && prettier . --check --log-level=warn && cspell --quiet",
    "prepare": "husky",
    "test": "pnpm run build && pnpm -r --if-present run test",
    "test:server": "pnpm --filter @marko/language-tools --filter @marko/language-server run build && pnpm --filter @marko/language-server run test:update"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "cspell": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "marko": "^5.39.25",
    "mocha": "^11.7.6",
    "mocha-snap": "^5.0.1",
    "prettier": "^3.9.6",
    "prettier-plugin-packagejson": "^3.0.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@11.15.1"
}
